{
	"manifest_version": 3,

	"name": "Imagus Reborn",
	"version": "2026.4.12",
	"description": "__MSG_APP_DESCRIPTION__",
	"default_locale": "en",
	"homepage_url": "https://www.reddit.com/r/Imagus",
	"browser_specific_settings": {
		"gecko": {
			"id": "{7653b5cb-d76d-442f-a98f-f3c83a118cf4}",
			"strict_min_version": "136.0",
			"data_collection_permissions": {
				"required": [ "none" ]
			}
		}
	},
	"icons": {
		"128": "common/img/icon.png"
	},

	"action": {
	},

	"permissions": [
		"notifications",
		"alarms",
		"downloads",
		"history",
		"contextMenus",
		"storage"
	],

	"optional_permissions": [
		"userScripts"
	],
	"host_permissions": [
		"<all_urls>"
	],

	"incognito": "spanning",

	"background": {
		"scripts": [ "background/service.js" ]
	},

	"options_ui": {
		"page": "options/options.html",
		"open_in_tab": true
	}
}
